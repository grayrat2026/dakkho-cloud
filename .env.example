# ==============================================================================
# DAKKHO — Cloud Services Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your actual credentials.
# NEVER commit .env to version control!
# ==============================================================================

# ── Cloudflare R2 ──────────────────────────────────────────
R2_BUCKET_NAME=dakkho-videos
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-your_account_id.r2.dev
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_API_TOKEN=your_r2_api_token

# ── LiveKit Cloud ───────────────────────────────────────────
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_WS_URL=wss://your_project.livekit.cloud
LIVEKIT_PROJECT_NAME=DAKKHO
LIVEKIT_MAX_PARTICIPANTS=100
LIVEKIT_MAX_ROOMS=5
LIVEKIT_FREE_TIER_MINUTES=10000

# ── OneSignal ───────────────────────────────────────────────
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key
ONESIGNAL_ANDROID_PACKAGE=com.grayrat.dakkho.student.pro.bd
ONESIGNAL_USER_AUTH_KEY=your_onesignal_user_auth_key

# ── Resend Email ────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
RESEND_DOMAIN=dakkho.com.bd
RESEND_SENDER_EMAIL=noreply@dakkho.com.bd
RESEND_SENDER_NAME=DAKKHO

# ── Appwrite Cloud ──────────────────────────────────────────
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_appwrite_project_id
APPWRITE_API_KEY=your_appwrite_api_key

# ── Optional: CDN Configuration ─────────────────────────────
CDN_BASE_URL=https://dakkho-videos.b-cdn.net
CDN_PROVIDER=bunny  # bunny | r2_direct | custom

# ── Optional: Firebase (for OneSignal FCM) ──────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_SERVER_KEY=your_firebase_server_key

# ── Optional: Monitoring ────────────────────────────────────
# SENTRY_DSN=your_sentry_dsn
# SENTRY_ENVIRONMENT=production
