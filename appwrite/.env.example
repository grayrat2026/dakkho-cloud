# =============================================================================
# DAKKHO (দক্ষ) — Appwrite Cloud Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running setup.sh
# =============================================================================

# --- Appwrite Core ---
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_appwrite_project_id
APPWRITE_API_KEY=your_appwrite_api_key_with_all_scopes

# --- LiveKit (Live Classes) ---
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# --- bKash Payment ---
BKASH_USERNAME=your_bkash_username
BKASH_PASSWORD=your_bkash_password
BKASH_APP_KEY=your_bkash_app_key
BKASH_APP_SECRET=your_bkash_app_secret
BKASH_SANDBOX=true

# --- Nagad Payment ---
NAGAD_MERCHANT_ID=your_nagad_merchant_id
NAGAD_MERCHANT_IP=your_server_ip
NAGAD_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
NAGAD_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
NAGAD_SANDBOX=true

# --- SSLCommerz Payment ---
SSLCOMMERZ_STORE_ID=your_sslcommerz_store_id
SSLCOMMERZ_STORE_PASSWORD=your_sslcommerz_store_password
SSLCOMMERZ_SANDBOX=true

# --- AI (Quiz Generation) ---
# Use one of: OpenAI or Gemini
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key

# --- Email (Resend) ---
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=DAKKHO <noreply@dakkho.com>

# --- Cloudflare R2 (Video Storage) ---
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=dakkho-videos-raw
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# --- Bunny CDN (Video Encoding) ---
BUNNY_API_KEY=
BUNNY_LIBRARY_ID=
BUNNY_STORAGE_ZONE=
BUNNY_PULL_ZONE=

# --- OneSignal (Push Notifications) ---
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key

# --- DRM ---
DRM_ENCRYPTION_KEY=your_widevine_encryption_key
